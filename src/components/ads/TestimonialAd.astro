---
import type { AstroBuiltinProps } from "astro";

export interface Testimonial {
  name: string;
  role: string;
  quote: string;
  ctaLabel: string;
  href: string;
  theme?: "dark" | "light";
}

export interface Props extends AstroBuiltinProps {
  testimonial?: Testimonial;
}

const {
  testimonial = {
    name: "Nombre Apellido",
    role: "Cargo · Organización",
    quote:
      "José Antonio aporta una combinación única de visión estratégica y excelencia técnica en cada proyecto que lidera.",
    ctaLabel: "Leer testimonio",
    href: "#",
    theme: "dark",
  },
} = Astro.props;

const themeClass = testimonial.theme === "light" ? "theme-light" : "theme-dark";
---

<aside class={`testimonial-ad ${themeClass}`}>
  <div class="accent-line"></div>
  <div class="ad-label">PUBLICIDAD</div>

  <div class="inner">
    <div class="quote-mark">“</div>

    <div class="content">
      <p class="quote">{testimonial.quote}</p>

      <div class="author">
        <span class="name">{testimonial.name}</span>
        <span class="role">{testimonial.role}</span>
      </div>

      <a
        href={testimonial.href}
        target="_blank"
        rel="noopener noreferrer"
        class="cta"
      >
        {testimonial.ctaLabel}
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</aside>

<style>
  .testimonial-ad {
    position: relative;
    border-radius: var(--radius-md);
    padding: 2.5rem;
    margin: 2.5rem 0;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-default);
  }

  .theme-dark {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .theme-light {
    background: var(--bg-primary);
    color: var(--text-primary);
  }

  .accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent-primary);
  }

  .ad-label {
    position: absolute;
    top: 0;
    right: 0;
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--text-secondary);
    color: var(--bg-primary);
    padding: 0.28rem 0.55rem;
    border-radius: 0 0 0 var(--radius-sm);
  }

  .theme-light .ad-label {
    background: var(--text-secondary);
  }

  .inner {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
  }

  .quote-mark {
    font-size: 5rem;
    font-family: var(--font-display);
    line-height: 0.7;
    color: var(--accent-primary);
    opacity: 0.85;
  }

  .content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .quote {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.6;
    margin: 0;
  }

  .author {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .name {
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .role {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    align-self: flex-start;
    padding: 0.75rem 0;
    border-radius: 0;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition:
      color var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
    border-bottom: 1px solid transparent;
  }

  .theme-dark .cta {
    background: transparent;
    color: var(--accent-primary);
  }

  .theme-light .cta {
    background: transparent;
    color: var(--accent-primary);
  }

  .cta:hover {
    transform: translateX(2px);
    border-bottom-color: currentColor;
  }

  .theme-dark .cta:hover {
    color: var(--accent-hover);
  }

  .theme-light .cta:hover {
    color: var(--accent-primary);
  }

  @media (max-width: 768px) {
    .testimonial-ad {
      padding: 2rem;
      margin: 2rem 0;
    }

    .inner {
      flex-direction: column;
      gap: 1rem;
    }

    .quote-mark {
      font-size: 4rem;
    }

    .quote {
      font-size: 1.2rem;
    }

    .cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
