---
const {
  title = "Stack Tecnológico AdTech",
  intro = "Tecnologías que utilizo para potenciar el revenue digital.",
  stacks = [
    {
      label: "Advertising & Data",
      items: [
        "Google Ad Manager",
        "Header Bidding",
        "Prebid.js",
        "Tag Manager",
      ],
    },
    {
      label: "Frontend",
      items: ["Astro", "React", "TypeScript", "TailwindCSS"],
    },
    {
      label: "Backend & DevOps",
      items: ["Node.js", "PHP / Symfony", "Docker", "AWS"],
    },
  ],
  ctaText = "Ver conocimientos",
  ctaLink = "/articulo-conocimientos",
} = Astro.props;
---

<div class="stack-skin">
  <div class="ad-label">ANUNCIO</div>
  <div class="accent-line"></div>

  <header class="header">
    <h3>{title}</h3>
    <p class="intro">{intro}</p>
  </header>

  <div class="stack-groups">
    {
      stacks.map((stack) => (
        <div class="stack-group">
          <span class="group-label">{stack.label}</span>
          <ul>
            {stack.items.map((item) => (
              <li>
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <a class="cta" href={ctaLink}>
    {ctaText}
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </a>
</div>

<style>
  .stack-skin {
    width: 100%;
    max-width: 300px;
    box-sizing: border-box;
    min-height: 580px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-5) var(--space-5) var(--space-5);
    color: var(--text-primary);
    transition:
      box-shadow var(--transition-base) var(--ease-default),
      border-color var(--transition-base) var(--ease-default);
  }

  .stack-skin:hover {
    box-shadow: var(--shadow-lg);
  }

  .ad-label {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--text-secondary);
    color: var(--bg-primary);
    padding: 0.28rem 0.55rem;
    border-radius: 0 0 0 var(--radius-sm);
    font-size: 0.52rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    z-index: 10;
  }

  .accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent-primary);
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  h3 {
    margin: 0;
    font-size: var(--text-xl);
    line-height: 1.25;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text-primary);
  }

  .intro {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .stack-groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    flex: 1;
  }

  .stack-group {
    padding: var(--space-3);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .group-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08rem;
    color: var(--accent-primary);
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-primary);
    line-height: 1.4;
  }

  li svg {
    color: var(--accent-primary);
    flex-shrink: 0;
  }

  .cta {
    margin-top: auto;
    background: var(--accent-primary);
    color: var(--bg-primary);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    font-weight: 600;
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    cursor: pointer;
    transition:
      opacity var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default);
  }

  .cta:hover {
    opacity: var(--opacity-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .cta svg {
    transition: transform var(--transition-base) var(--ease-default);
  }

  .cta:hover svg {
    transform: translateX(2px);
  }

  @media (max-width: 1100px) {
    .stack-skin {
      max-width: 100%;
      min-height: auto;
      border-radius: 0;
    }
  }
</style>
