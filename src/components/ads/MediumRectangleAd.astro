---
// Formato IAB Medium Rectangle: 300x250
export interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  icon?: string;
}

const {
  title = "Stack Tecnológico AdTech",
  description = "Google Ad Manager • Header Bidding • JavaScript • React • PHP • Node.js",
  ctaText = "Ver más tecnologías",
  ctaLink = "#",
  icon = "tech",
} = Astro.props;
---

<div class="medium-rectangle-ad">
  <div class="ad-label">Anuncio</div>

  <div class="ad-content">
    {
      icon === "tech" && (
        <div class="icon-container">
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="16 18 22 12 16 6" />
            <polyline points="8 6 2 12 8 18" />
          </svg>
        </div>
      )
    }

    {
      icon === "contact" && (
        <div class="icon-container">
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
        </div>
      )
    }

    {
      icon === "project" && (
        <div class="icon-container">
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
          </svg>
        </div>
      )
    }

    <h3>{title}</h3>
    <p>{description}</p>

    <a href={ctaLink} class="cta-button">
      {ctaText}
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</div>

<style>
  .medium-rectangle-ad {
    width: 300px;
    height: 250px;
    background: linear-gradient(
      135deg,
      rgba(138, 43, 226, 0.2),
      rgba(74, 144, 226, 0.2)
    );
    border: 2px solid rgba(225, 188, 38, 0.3);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
  }

  .medium-rectangle-ad:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 25px rgba(225, 188, 38, 0.4);
    border-color: rgba(225, 188, 38, 0.5);
  }

  .ad-label {
    position: absolute;
    top: 8px;
    right: 8px;
    background-color: rgba(0, 0, 0, 0.5);
    color: rgba(255, 255, 255, 0.7);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 10;
  }

  .ad-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 1.5rem;
    text-align: center;
  }

  .icon-container {
    width: 80px;
    height: 80px;
    background: rgba(225, 188, 38, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: #e1bc26;
  }

  h3 {
    font-size: 1.3rem;
    font-weight: bold;
    color: #ffffff;
    margin: 0 0 0.75rem 0;
    line-height: 1.3;
  }

  p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 1.25rem 0;
    line-height: 1.5;
  }

  .cta-button {
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    color: white;
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cta-button:hover {
    background: linear-gradient(135deg, #5ba3f5, #2563a0);
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(74, 144, 226, 0.5);
  }

  .cta-button svg {
    transition: transform 0.3s ease;
  }

  .cta-button:hover svg {
    transform: translateX(3px);
  }
</style>
