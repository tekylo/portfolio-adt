---

<div class="theme-toggle">
  <button
    id="themeToggle"
    data-next-theme="light"
    aria-label="Cambiar a modo claro"
  >
    <span class="toggle-text">
      <span class="label-light">Modo Claro</span>
      <span class="label-dark">Modo Oscuro</span>
    </span>
    <span class="toggle-icon" aria-hidden="true">
      <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24">
        <path
          fill-rule="evenodd"
          d="M12 17.5a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zm0 1.5a7 7 0 1 0 0-14 7 7 0 0 0 0 14zm12-7a.8.8 0 0 1-.8.8h-2.4a.8.8 0 0 1 0-1.6h2.4a.8.8 0 0 1 .8.8zM4 12a.8.8 0 0 1-.8.8H.8a.8.8 0 0 1 0-1.6h2.5a.8.8 0 0 1 .8.8zm16.5-8.5a.8.8 0 0 1 0 1l-1.8 1.8a.8.8 0 0 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM6.3 17.7a.8.8 0 0 1 0 1l-1.7 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM12 0a.8.8 0 0 1 .8.8v2.5a.8.8 0 0 1-1.6 0V.8A.8.8 0 0 1 12 0zm0 20a.8.8 0 0 1 .8.8v2.4a.8.8 0 0 1-1.6 0v-2.4a.8.8 0 0 1 .8-.8zM3.5 3.5a.8.8 0 0 1 1 0l1.8 1.8a.8.8 0 1 1-1 1L3.5 4.6a.8.8 0 0 1 0-1zm14.2 14.2a.8.8 0 0 1 1 0l1.8 1.7a.8.8 0 0 1-1 1l-1.8-1.7a.8.8 0 0 1 0-1z"
        ></path>
      </svg>
      <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24">
        <path
          fill-rule="evenodd"
          d="M16.5 6A10.5 10.5 0 0 1 4.7 16.4 8.5 8.5 0 1 0 16.4 4.7l.1 1.3zm-1.7-2a9 9 0 0 1 .2 2 9 9 0 0 1-11 8.8 9.4 9.4 0 0 1-.8-.3c-.4 0-.8.3-.7.7a10 10 0 0 0 .3.8 10 10 0 0 0 9.2 6 10 10 0 0 0 4-19.2 9.7 9.7 0 0 0-.9-.3c-.3-.1-.7.3-.6.7a9 9 0 0 1 .3.8z"
        ></path>
      </svg>
    </span>
  </button>
</div>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: system-ui, sans-serif;
  }

  #themeToggle {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--border-medium);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    cursor: pointer;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    font-size: 0.7rem;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  #themeToggle:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--accent-primary);
  }

  .toggle-text {
    display: inline-flex;
    gap: 0.6rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .toggle-icon {
    display: inline-flex;
  }

  .label-light,
  .label-dark,
  .icon-sun,
  .icon-moon {
    display: none;
  }

  #themeToggle[data-next-theme="light"] .label-light,
  #themeToggle[data-next-theme="light"] .icon-sun {
    display: inline;
  }

  #themeToggle[data-next-theme="dark"] .label-dark,
  #themeToggle[data-next-theme="dark"] .icon-moon {
    display: inline;
  }

  .icon-sun path {
    fill: var(--accent-primary);
  }

  .icon-moon path {
    fill: var(--accent-secondary);
  }

  @media (max-width: 768px) {
    #themeToggle {
      padding: 0.35rem 0.7rem;
      gap: 0.5rem;
      font-size: 0.65rem;
      letter-spacing: 0.06rem;
    }

    .toggle-text {
      gap: 0.45rem;
    }

    .toggle-icon svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
