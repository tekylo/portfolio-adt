---
// Formato IAB Medium Rectangle: 300x250
export interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  icon?: string;
}

const {
  title = "Stack Tecnológico AdTech",
  description = "Google Ad Manager • Header Bidding • JavaScript • React • PHP • Node.js",
  ctaText = "Ver más tecnologías",
  ctaLink = "#",
  icon = "tech",
} = Astro.props;
---

<div class="medium-rectangle-ad">
  <div class="ad-label">Anuncio</div>

  <div class="ad-content">
    {
      icon === "tech" && (
        <div class="icon-container">
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="16 18 22 12 16 6" />
            <polyline points="8 6 2 12 8 18" />
          </svg>
        </div>
      )
    }

    {
      icon === "contact" && (
        <div class="icon-container">
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
        </div>
      )
    }

    {
      icon === "project" && (
        <div class="icon-container">
          <svg
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
          </svg>
        </div>
      )
    }

    <h3>{title}</h3>
    <p>{description}</p>

    <a href={ctaLink} class="cta-button">
      {ctaText}
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</div>

<style>
  .medium-rectangle-ad {
    width: 300px;
    height: 250px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
  }

  .medium-rectangle-ad:hover {
    transform: scale(1.03);
    box-shadow: var(--shadow-md);
    border-color: var(--border-default);
  }

  .ad-label {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    background-color: rgba(0, 0, 0, 0.5);
    color: rgba(255, 255, 255, 0.7);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 10;
  }

  .ad-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: var(--space-6);
    text-align: center;
  }

  .icon-container {
    width: 80px;
    height: 80px;
    background: var(--accent-muted);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    color: var(--accent-primary);
    transition: background-color var(--transition-base) var(--ease-default);
  }

  h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: bold;
    color: var(--text-primary);
    margin: 0 0 var(--space-3) 0;
    line-height: 1.3;
  }

  p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0 0 var(--space-5) 0;
    line-height: 1.5;
  }

  .cta-button {
    background: var(--accent-primary);
    color: var(--bg-primary);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    transition:
      opacity var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cta-button:hover {
    opacity: var(--opacity-hover);
    transform: scale(1.05);
  }

  .cta-button svg {
    transition: transform var(--transition-base) var(--ease-default);
  }

  .cta-button:hover svg {
    transform: translateX(3px);
  }
</style>
