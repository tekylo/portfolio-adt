import LogosMicrosoftIcon from "../svgs/LogosMicrosoftIcon.astro";
import LogosMicrosoftTeams from "../svgs/LogosMicrosoftTeams.astro";
import LogosMicrosoftWindowsIcon from "../svgs/LogosMicrosoftWindowsIcon.astro";
import LogosMondayIcon from "../svgs/LogosMondayIcon.astro";
import LogosMongodbIcon from "../svgs/LogosMongodbIcon.astro";
import LogosMysql from "../svgs/LogosMysql.astro";
import LogosNewRelicIcon from "../svgs/LogosNewRelicIcon.astro";
import LogosNodejs from "../svgs/LogosNodejs.astro";
import LogosNotionIcon from "../svgs/LogosNotionIcon.astro";
import LogosNpmIcon from "../svgs/LogosNpmIcon.astro";
