---
// Menú de navegación estilo El País
const navItems = [
  { label: "SOBRE MÍ", href: "/articulo-sobre-mi" },
  { label: "EDUCACIÓN", href: "/articulo-educacion" },
  { label: "EXPERIENCIA", href: "/articulo-experiencia" },
  { label: "PROYECTOS", href: "/articulo-proyectos" },
  { label: "CURSOS", href: "/articulo-cursos" },
  { label: "CONOCIMIENTOS", href: "/articulo-conocimientos" },
];
---

<nav class="nav-menu">
  <div class="nav-container">
    <ul class="nav-list">
      {
        navItems.map((item) => (
          <li class="nav-item">
            <a href={item.href} class="nav-link">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .nav-menu {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-primary);
    transition: background-color var(--transition-base) var(--ease-default);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-4);
    border-bottom: 1px solid var(--border-default);
  }

  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .nav-list::-webkit-scrollbar {
    display: none;
  }

  .nav-item {
    flex-shrink: 0;
  }

  .nav-link {
    display: block;
    padding: var(--space-4) var(--space-5);
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: var(--text-sm);
    letter-spacing: 0.5px;
    border-bottom: 2px solid transparent;
    transition:
      color var(--transition-base) var(--ease-default),
      border-color var(--transition-base) var(--ease-default);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--text-primary);
    border-bottom-color: var(--accent-primary);
  }

  .nav-link:active,
  .nav-link.active {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-container {
      padding: 0 var(--space-2);
    }

    .nav-link {
      padding: var(--space-3) var(--space-4);
      font-size: var(--text-xs);
    }
  }

  @media (max-width: 480px) {
    .nav-link {
      padding: var(--space-3) var(--space-3);
      font-size: 0.75rem;
    }
  }
</style>
