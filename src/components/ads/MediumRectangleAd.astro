---
// Formato IAB Medium Rectangle: 300x250
export interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  icon?: string;
}

const {
  title = "Stack Tecnológico AdTech",
  description = "Google Ad Manager • Header Bidding • JavaScript • React • PHP • Node.js",
  ctaText = "Ver más tecnologías",
  ctaLink = "#",
  icon = "tech",
} = Astro.props;
---

<div class="medium-rectangle-ad">
  <div class="ad-label">Anuncio</div>
  <div class="accent-line"></div>

  <div class="ad-content">
    <header class="ad-header">
      <div class="icon-small">
        {
          icon === "tech" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
          )
        }
        {
          icon === "contact" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
          )
        }
        {
          icon === "project" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
            </svg>
          )
        }
      </div>
      <h3>{title}</h3>
    </header>

    <p class="description">{description}</p>

    <footer class="ad-footer">
      <a href={ctaLink} class="cta-button">
        {ctaText}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <span class="placement-hint">AdTech Consulting</span>
    </footer>
  </div>
</div>

<style>
  .medium-rectangle-ad {
    width: 300px;
    height: 250px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
  }

  .medium-rectangle-ad:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-md);
    border-color: var(--border-default);
  }

  .ad-label {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    background-color: rgba(0, 0, 0, 0.4);
    color: rgba(255, 255, 255, 0.7);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 10;
  }

  .accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent-primary);
  }

  .ad-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-4) var(--space-4) var(--space-3) var(--space-5);
  }

  .ad-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .icon-small {
    width: 36px;
    height: 36px;
    background: rgba(212, 160, 23, 0.1);
    border: 1px solid rgba(212, 160, 23, 0.2);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-primary);
  }

  h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .description {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin: auto 0 0 0;
    line-height: 1.5;
    opacity: 0.85;
  }

  .ad-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
  }

  .cta-button {
    background: var(--accent-primary);
    color: var(--bg-primary);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: var(--text-xs);
    text-decoration: none;
    transition:
      opacity var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  .cta-button:hover {
    opacity: var(--opacity-hover);
    transform: translateY(-1px);
  }

  .cta-button svg {
    transition: transform var(--transition-base) var(--ease-default);
  }

  .cta-button:hover svg {
    transform: translateX(2px);
  }

  .placement-hint {
    font-size: 0.55rem;
    color: var(--text-tertiary);
    text-align: center;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }
</style>