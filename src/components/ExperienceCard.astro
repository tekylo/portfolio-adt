---
// Props que recibirá el componente
export interface Props {
  companyName: string;
  logoUrl: string;
  dateRange: string;
  jobDescription: string[];
}

const { companyName, logoUrl, dateRange, jobDescription } = Astro.props;
---

<div class="experience-ad-card">
  <div class="ad-label">Sponsored</div>

  <div class="company-header">
    <div class="company-logo">
      <img src={logoUrl} alt={companyName + " logo"} />
    </div>
    <div class="company-info">
      <h3>{companyName}</h3>
      <div class="date-range">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span>{dateRange}</span>
      </div>
    </div>
  </div>

  <div class="experience-content">
    <ul class="responsibilities">
      {
        jobDescription.map((desc) => (
          <li>
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>{desc}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="card-footer">
    <button class="learn-more-btn">
      Más información
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </button>
  </div>
</div>

<style>
  .experience-ad-card {
    background: linear-gradient(
      135deg,
      rgba(74, 144, 226, 0.1),
      rgba(26, 81, 134, 0.1)
    );
    border: 2px solid rgba(225, 188, 38, 0.3);
    border-radius: 12px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
    position: relative;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
  }

  .experience-ad-card:hover {
    transform: translateX(10px);
    box-shadow: 0 8px 30px rgba(225, 188, 38, 0.3);
    border-color: rgba(225, 188, 38, 0.6);
  }

  .ad-label {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0, 0, 0, 0.5);
    color: rgba(255, 255, 255, 0.7);
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .company-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(225, 188, 38, 0.2);
  }

  .company-logo {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .company-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 8px;
  }

  .company-info {
    flex: 1;
  }

  .company-info h3 {
    font-size: 1.5rem;
    font-weight: bold;
    color: #ffffff;
    margin: 0 0 0.5rem 0;
  }

  .date-range {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #e1bc26;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .date-range svg {
    color: #e1bc26;
  }

  .experience-content {
    margin-bottom: 1.25rem;
  }

  .responsibilities {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .responsibilities li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .responsibilities li svg {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--accent-secondary);
  }

  .responsibilities li span {
    flex: 1;
  }

  .card-footer {
    display: flex;
    justify-content: flex-end;
  }

  .learn-more-btn {
    background: linear-gradient(135deg, #e1bc26, #ffd700);
    color: #1a1a1a;
    border: none;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .learn-more-btn:hover {
    background: linear-gradient(135deg, #ffd700, #ffed4a);
    transform: scale(1.05);
    box-shadow: 0 4px 15px rgba(225, 188, 38, 0.5);
  }

  .learn-more-btn svg {
    transition: transform 0.3s ease;
  }

  .learn-more-btn:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .experience-ad-card {
      padding: 1.25rem;
    }

    .experience-ad-card:hover {
      transform: translateY(-5px);
    }

    .company-header {
      flex-direction: column;
      gap: 1rem;
    }

    .company-logo {
      width: 70px;
      height: 70px;
      align-self: center;
    }

    .company-info h3 {
      font-size: 1.3rem;
      text-align: center;
    }

    .date-range {
      justify-content: center;
    }

    .responsibilities li {
      font-size: 0.9rem;
    }

    .card-footer {
      justify-content: center;
    }
  }
</style>
