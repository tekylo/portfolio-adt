---
const {
  title = "Stack Tecnológico AdTech",
  intro = "Tecnologías que utilizo para potenciar el revenue digital.",
  stacks = [
    {
      label: "Advertising & Data",
      items: [
        "Google Ad Manager",
        "Header Bidding",
        "Prebid.js",
        "Tag Manager",
      ],
    },
    {
      label: "Frontend",
      items: ["Astro", "React", "TypeScript", "TailwindCSS"],
    },
    {
      label: "Backend & DevOps",
      items: ["Node.js", "PHP / Symfony", "Docker", "AWS"],
    },
  ],
  ctaText = "Ver conocimientos",
  ctaLink = "/articulo-conocimientos",
} = Astro.props;
---

<div class="stack-skin">
  <div class="ad-label">ANUNCIO</div>

  <header class="header">
    <h3>{title}</h3>
    <p>{intro}</p>
  </header>

  <div class="stack-groups">
    {
      stacks.map((stack) => (
        <div class="stack-group">
          <span class="group-label">{stack.label}</span>
          <ul>
            {stack.items.map((item) => (
              <li>
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <a class="cta" href={ctaLink}>
    {ctaText}
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </a>
</div>

<style>
  .stack-skin {
    width: 100%;
    max-width: 300px;
    box-sizing: border-box;
    min-height: 600px;
    background: var(--ad-bg, #232946);
    box-shadow: 0 4px 18px var(--ad-shadow, rgba(35, 41, 70, 0.18));
    border: 1px solid var(--ad-border, #121629);
    padding: 1.6rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    color: var(--text-primary);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .stack-skin:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 48px rgba(99, 102, 241, 0.35);
  }

  .ad-label {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0, 0, 0, 0.45);
    color: rgba(255, 255, 255, 0.7);
    padding: 0.25rem 0.6rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 600;
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    color: #f3f4f6;
  }

  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.28rem;
    font-size: 0.65rem;
    color: var(--text-secondary);
    opacity: 0.85;
    font-weight: 700;
  }

  h3 {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.3;
    font-family: Georgia, "Times New Roman", serif;
  }

  .header p {
    margin: 0;
    font-size: 0.9rem;
    color: #f3f4f6;
  }

  .stack-groups {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .stack-group {
    background: rgba(255, 255, 255, 0.22);
    padding: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    backdrop-filter: blur(12px);
    border: 1px solid rgba(225, 188, 38, 0.3);
  }

  :root {
    --ad-bg: #232946;
    --ad-accent: #eebd3d;
    --ad-text: #fff;
    --ad-border: #121629;
    --ad-radius: 8px;
    --ad-shadow: 0 4px 18px rgba(35, 41, 70, 0.18);
    --ad-box: 0 2px 8px rgba(35, 41, 70, 0.12);
    --ad-box-hover: 0 4px 16px rgba(35, 41, 70, 0.18);
    --ad-bg-light: #f3f4f6;
    --ad-border-light: #e5e7eb;
    --ad-text-dark: #222;
    --ad-text-muted: #444;
  }

  .stack-skin {
    width: 100%;
    max-width: 300px;
    box-sizing: border-box;
    min-height: 600px;
    background: var(--ad-bg);
    border: 2px solid var(--ad-border);
    border-radius: 0;
    padding: 1.6rem;
    box-shadow: var(--ad-shadow);
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    color: var(--ad-text);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.85rem;
    color: #f3f4f6;
    line-height: 1.35;
  }

  li svg {
    color: #eebd3d !important;
  }

  .cta {
    align-self: stretch;
    border-radius: 8px;
    padding: 0.8rem 1.6rem;
    background: #232946;
    color: #eebd3d;
    border: 2px solid #eebd3d;
    font-weight: 700;
    font-size: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    box-shadow: 0 2px 8px rgba(35, 41, 70, 0.12);
    letter-spacing: 0.5px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0.8, 0.4, 1);
  }

  .cta:hover {
    background: #eebd3d;
    color: #232946;
    box-shadow: 0 4px 16px rgba(35, 41, 70, 0.18);
    transform: scale(1.05);
  }
  .cta svg {
    color: #e8eaed;
  }

  @media (max-width: 1100px) {
    .stack-skin {
      max-width: 100%;
    }
  }
</style>
