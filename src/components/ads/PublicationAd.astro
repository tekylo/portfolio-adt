---
export interface Publication {
  title: string;
  summary: string;
  ctaLabel: string;
  href: string;
  theme?: "dark" | "light";
}

export interface Props {
  publication?: Publication;
}

const {
  publication = {
    title: "Título de la publicación",
    summary:
      "Resumen breve del contenido para invitar a leer el artículo completo en la plataforma original.",
    ctaLabel: "Leer publicación",
    href: "#",
    theme: "dark",
  },
} = Astro.props;

const themeClass =
  publication.theme === "light" ? "publication-theme-light" : "publication-theme-dark";
---

<section class={`publication-ad ${themeClass}`}>
  <div class="accent-line"></div>
  <div class="label">PUBLICIDAD</div>
  <div class="content">
    <div class="copy-block">
      <h3>{publication.title}</h3>
      <p>{publication.summary}</p>
    </div>
    <a
      href={publication.href}
      target="_blank"
      rel="noopener noreferrer"
      class="cta"
    >
      {publication.ctaLabel}
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</section>

<style>
  .publication-ad {
    position: relative;
    width: 100%;
    max-width: 728px;
    min-height: 90px;
    margin: 3rem auto;
    padding: 1rem 1.25rem 1rem 1.5rem;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-default);
    box-shadow: var(--shadow-sm);
  }

  .publication-theme-dark {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .publication-theme-light {
    background: var(--bg-primary);
    color: var(--text-primary);
  }

  .accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent-primary);
  }

  .label {
    position: absolute;
    top: 0;
    right: 0;
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--text-secondary);
    color: var(--bg-primary);
    padding: 0.28rem 0.55rem;
    border-radius: 0 0 0 var(--radius-sm);
    z-index: 1;
  }

  .publication-theme-light .label {
    background: var(--text-secondary);
  }

  .content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    min-height: 58px;
  }

  .copy-block {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  h3 {
    font-size: 1.15rem;
    margin: 0;
    font-family: var(--font-display);
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.01em;
    max-width: calc(100% - 4rem);
  }

  .content p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.35;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.8rem;
    transition:
      background-color var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .publication-theme-dark .cta {
    background: var(--accent-primary);
    color: var(--bg-primary);
  }

  .publication-theme-light .cta {
    background: var(--accent-primary);
    color: var(--bg-primary);
  }

  .cta:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .publication-theme-dark .cta:hover {
    background: var(--accent-hover);
  }

  .publication-theme-light .cta:hover {
    background: var(--accent-hover);
  }

  .cta svg {
    transition: transform var(--transition-base) var(--ease-default);
  }

  .cta:hover svg {
    transform: translateX(2px);
  }

  @media (max-width: 768px) {
    .publication-ad {
      min-height: auto;
      padding: 1rem 1rem 1rem 1.25rem;
      margin: 2.5rem 0;
    }

    .content {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.85rem;
    }

    h3 {
      max-width: none;
      font-size: 1.05rem;
    }

    .content p {
      font-size: 0.85rem;
    }

    .label {
      top: 10px;
      right: 10px;
    }

    .cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
