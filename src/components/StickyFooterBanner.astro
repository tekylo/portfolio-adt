---

<div class="sticky-side-banner">
  <div class="banner-content">
    <h2>STACK TECNOLÓGICO</h2>
    <div class="card__tags">
      <LogosGoogleAds />
      <LogosGoogleAdsense />
      <LogosGoogleTagManager />
      <LogosGoogleDevelopersIcon />
      <LogosMicrosoftIcon />
      <LogosJavascript />
      <LogosReact />
      <LogosTypescriptIcon />
      <LogosNodejs />
      <LogosPhp />
      <LogosSymfony />
      <LogosAngularIcon />
      <LogosTailwindcssIcon />
      <LogosCss3 />
      <LogosAstroIcon />
      <LogosHtml5 />
      <LogosMongodbIcon />
      <LogosNpmIcon />
      <LogosPnpm />
      <LogosMysql />
      <LogosPostgresql />
      <LogosPython />
      <LogosRLang />
      <LogosJava />
      <LogosC />
      <LogosCPlusPlus />
      <LogosEsbuild />
      <LogosWebpack />
      <LogosBabel />
      <LogosWordpressIcon />
      <LogosMagento />
      <LogosVisualStudioCode />
      <LogosJetbrains />
      <LogosNewRelicIcon />
      <LogosJenkins />
      <LogosAws />
      <LogosDockerIcon />
      <LogosLinuxTux />
      <LogosUbuntu />
      <LogosMicrosoftWindowsIcon />
      <LogosMacos />
      <LogosGitIcon />
      <LogosGithubIcon />
      <LogosBitbucket />
      <LogosJira />
      <LogosConfluence />
      <LogosMondayIcon />
      <LogosNotionIcon />
      <LogosSublimetextIcon />
      <LogosMicrosoftTeams />
      <LogosSlackIcon />
    </div>
  </div>
  <button class="close-button" aria-label="Cerrar banner">×</button>
  <div class="ad-label">Anuncio</div>
</div>

<style>
  .sticky-side-banner {
    position: sticky;
    top: 20px;
    width: 100%;
    background: linear-gradient(135deg, #333333, #1a1a1a);
    color: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    margin-bottom: 20px;
  }

  .banner-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  h2 {
    margin: 0;
    font-size: 1.2rem;
    color: #e1bc26;
  }

  p {
    margin: 0;
    font-size: 1rem;
  }

  .cta-button {
    background-color: var(--accent-primary);
    color: var(--bg-primary);
    border: none;
    padding: 10px 20px;
    border-radius: 5px;
    cursor: pointer;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }

  .cta-button:hover {
    background-color: #ffed4a;
  }

  .close-button {
    position: absolute;
    top: 10px;
    right: 10px;
    background: none;
    border: none;
    color: white;
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0;
  }

  .ad-label {
    position: absolute;
    top: 10px;
    right: 25px;
    background-color: rgba(0, 0, 0, 0.5);
    padding: 2px 6px;
    font-size: 0.7rem;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
  }

  .card__tags {
    padding: 10px;
  }

  .tags {
    display: flex;
    gap: 12px;
  }

  .tags span {
    background-color: #e2e8f0;
    padding: 8px 16px;
    border-radius: 9999px;
    font-size: 13px;
    color: #333;
  }

  @media (max-width: 1024px) {
    .sticky-side-banner {
      position: static;
      width: auto;
      margin-bottom: 20px;
    }
  }

  @media (max-width: 768px) {
    .sticky-side-banner {
      width: 100%;
      max-width: 100%;
    }

    .banner-content h2 {
      font-size: 1.3rem;
      text-align: center;
    }

    .card__tags {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(40px, 1fr));
      gap: 0.5rem;
      justify-items: center;
    }
  }

  @media (max-width: 480px) {
    .banner-content h2 {
      font-size: 1.1rem;
    }

    .card__tags {
      grid-template-columns: repeat(auto-fit, minmax(35px, 1fr));
      gap: 0.35rem;
    }

    .close-button {
      width: 30px;
      height: 30px;
      font-size: 1.2rem;
    }
  }
</style>

<script>
  const closeButton = document.querySelector(".close-button");
  const banner = document.querySelector(".sticky-side-banner") as HTMLElement;

  if (closeButton && banner) {
    closeButton.addEventListener("click", () => {
      banner.style.display = "none";
    });
  }
</script>
