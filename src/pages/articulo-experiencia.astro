---
import Layout from "../layouts/Layout.astro";
import NavMenu from "../components/NavMenu.astro";
import NewspaperHeader from "../components/NewspaperHeader.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import articles from "../data/articles.json";
import TestimonialAd from "../components/ads/TestimonialAd.astro";
import recommendations from "../data/recommendations.json";
const article = articles.find((a) => a.slug === "experiencia");
const data = article!;
const formatDate = (date: Date) => new Intl.DateTimeFormat("es-ES", { day: "numeric", month: "long", year: "numeric" }).format(date);
const today = formatDate(new Date());
const ilocadTestimonial = recommendations.find((r) => r.slug === "ilocad")!;
const fibgarTestimonial = recommendations.find((r) => r.slug === "fibgar")!;

const experiences = [
  {
    company: "Wemass",
    role: "AdTech",
    site: "https://wemass.com/",
    siteLabel: "wemass.com",
    logo: "/logos/wemass.png",
    period: "2025 — Actualidad",
    summary:
      "El marketplace de audiencias impulsado por Vocento, Godó y Prisa donde lidero formatos publicitarios avanzados como el Skin con tecnología propia.",
    details: [
      "Coordino proyectos end-to-end que abarcan plantillas publicitarias, integraciones programáticas y despliegues automatizados mediante CI/CD.",
      "Defino flujos de trabajo entre operaciones, diseño e IT para garantizar eficiencia y consistencia técnica en cada lanzamiento.",
      "Participo en la implementación de OpenRTB, Header Bidding y soluciones cookieless, contribuyendo a la evolución tecnológica del marketplace."
    ],
    stack:
      "Go, Node.js, TypeScript, PHP, Google Ad Manager, AWS S3, Kibana, Cloudflare"
  },
  {
    company: "Arkeero",
    role: "AdTech Lead",
    site: "https://arkeero.com/",
    siteLabel: "arkeero.com",
    logo: "/logos/arkeero.jpeg",
    period: "2023 — 2025",
    summary:
      "Lideré el ciclo completo de proyectos publicitarios del grupo, desarrollando una librería transversal junto a David Berrocal que integraba Prebid.js.",
    details: [
      "Orquesté la migración del ecosistema programático a Xandr asegurando continuidad operativa y control de métricas.",
      "Impulsé integraciones cookieless, creación de plantillas multisite y despliegues de Header Bidding tanto client-side como server-side, alineando tecnología con ventas y diseño."
    ],
    stack: "JavaScript, TypeScript, React, Node.js, MongoDB, Google Ad Manager"
  },
  {
    company: "Vocento",
    role: "Arquitecto de Soluciones de Publicidad",
    site: "https://www.vocento.com/",
    siteLabel: "vocento.com",
    logo: "/logos/vocento.png",
    period: "2022 — 2023",
    summary:
      "Co-lideré el cambio de adserver de Google Ad Manager a Equativ (Smart AdServer) y su posterior reversión técnica, asentando la metodología del área de publicidad.",
    details: [
      "Aseguré la calidad del código y la documentación técnica durante la transición.",
      "Proporcioné soporte a Team Leaders y Delivery Managers en tareas de refinado y validación funcional, integrando negocio y tecnología."
    ],
    stack: "Symfony, Node.js, React, JavaScript, MySQL, MongoDB, Google Ad Manager"
  },
  {
    company: "Meytel",
    role: "Full Stack Developer",
    site: "https://www.meytel.net/",
    siteLabel: "meytel.net",
    logo: "/logos/meytel.png",
    period: "2018 — 2022",
    summary:
      "Senior Developer y Team Leader del equipo publicitario para Vocento, diseñando librerías publicitarias en JavaScript y proyectos en React.",
    details: [
      "Integré soluciones en Symfony, desarrollé plugins personalizados en WordPress y aseguré el rendimiento en entornos de alta carga.",
      "Apliqué metodologías Scrum, GitFlow y Jenkins con foco en Clean Code, testing y rendimiento."
    ],
    stack: "Symfony, JavaScript, MySQL, MongoDB, WordPress, Google Ad Manager"
  },
  {
    company: "Pulsar Technologies",
    role: "Full Stack Developer",
    site: "https://pulsartec.es/en/specialists-in-technology-solutions/",
    siteLabel: "pulsartec.es",
    logo: "/logos/pulsar.png",
    period: "2017 — 2018",
    summary:
      "Desarrollé aplicaciones web con frameworks propios para NetApp, trabajando con PHP, Angular 5 y MySQL en entornos de misión crítica.",
    details: [
      "Atendí incidencias técnicas en entornos internacionales colaborando con equipos de soporte en inglés mediante Redmine."
    ],
    stack: "PHP, Angular, Symfony, MySQL"
  },
  {
    company: "Quantion",
    role: "Desarrollador de Software",
    site: "https://www.quantion.es/",
    siteLabel: "quantion.es",
    logo: "/logos/quantion.png",
    period: "2016 — 2017",
    summary:
      "Desarrollé aplicaciones AngularJS para entornos hospitalarios y hoteleros, conectando dispositivos y sistemas multimedia.",
    details: [
      "Diseñé APIs REST y bases de datos para proyectos en los hospitales Sanitas La Moraleja y Sanitas La Zarzuela de Madrid."
    ],
    stack: "AngularJS, REST API, MySQL"
  },
  {
    company: "ILOCAD · Baltasar Garzón Abogados",
    role: "Técnico Informático",
    site: "https://www.ilocad.info/",
    siteLabel: "ilocad.info",
    logo: "/logos/ilocad.png",
    period: "2015",
    summary:
      "Actualicé la presencia digital del despacho en Joomla, reforzando seguridad y mantenimiento de servidores.",
    details: [
      "Recibí una carta de recomendación por el trabajo realizado, que consolidó la confianza del despacho en la estrategia digital."
    ],
    link: {
      href: "https://www.dropbox.com/scl/fi/wu18ulela2w7pvu6htajy/Certificado-ILOCAD.pdf?rlkey=45qk8xt8mmzcz4218fgz4ui0j&e=1&dl=0",
      label: "📝 Ver carta de recomendación"
    },
    stack: "WordPress, Joomla",
    testimonial: ilocadTestimonial
  },
  {
    company: "FIBGAR",
    role: "Técnico Informático",
    site: "https://fibgar.es/",
    siteLabel: "fibgar.es",
    logo: "/logos/fibgar.png",
    period: "2014",
    summary:
      "Mantuve servidores y desarrollé web en WordPress, colaborando en un proyecto de videojuego educativo para dispositivos móviles.",
    details: [
      "Aporté soporte continuado al equipo interno y reforcé la infraestructura digital de la fundación."
    ],
    link: {
      href: "https://www.dropbox.com/scl/fi/wf94ddjpo2wsczx04hlaw/CERTIFICADO-FIBGAR.pdf?rlkey=8blnj6budtosii36tdr2c4vt9&e=1&dl=0",
      label: "📝 Ver carta de recomendación"
    },
    stack: "WordPress, Android, iOS",
    testimonial: fibgarTestimonial
  }
];
---

<Layout title="Experiencia Profesional | El Diario AdTech">
  <div class="container">
    <NewspaperHeader />
  </div>
  <NavMenu />

  <div class="container">
    <Breadcrumbs
      items={[{ label: "Portada", href: "/" }, { label: "Experiencia" }]}
    />
  </div>

  <div class="container">
    <div class="article-page">
      <div class="featured-image">
        <img
          src={data.imageUrl}
          alt={data.title}
          transition:name="article-/articulo-experiencia"
        />
        <span class="category-badge">{data.category}</span>
      </div>

      <article class="full-article">
        <h1 class="article-title" transition:name="title-/articulo-experiencia">
          {data.title}
        </h1>

        <div class="article-meta">
          <span class="date">{today}</span>
          <span class="separator">|</span>
          <span class="author">{data.author}</span>
        </div>

        <p class="lead">
          {data.subtitle}
        </p>

        <div class="article-content">
          <p>
            Con más de ocho años de experiencia, José Antonio López Molina ha
            construido su carrera en el corazón del ecosistema publicitario
            digital, colaborando con grupos líderes en España. Su trayectoria
            combina desarrollo técnico, liderazgo de proyectos y visión
            estratégica para alinear negocio, ingeniería y optimización
            programática.
          </p>

          <p>
            🧭 Cada rol ha sumado capas de producto, tecnología y coordinación
            para llevar soluciones AdTech desde la idea hasta la ejecución.
          </p>

          <div class="timeline">
            {experiences.map((experience) => (
              <section class="timeline-item">
                <div class="timeline-node">
                  <span class="timeline-dot" aria-hidden="true"></span>
                </div>
                <div class="timeline-card">
                  <header class="timeline-card-header">
                    <div class="timeline-logo-wrapper">
                      <img
                        src={experience.logo}
                        alt={`Logo de ${experience.company}`}
                        loading="lazy"
                      />
                    </div>
                    <div class="timeline-heading">
                      <h2>{experience.company}</h2>
                      <a
                        href={experience.site}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="timeline-link"
                      >
                        {experience.siteLabel}
                      </a>
                    </div>
                  </header>

                  <div class="timeline-meta">
                    <span class="timeline-role">{experience.role}</span>
                    <span class="timeline-period">{experience.period}</span>
                  </div>

                  <p class="timeline-summary">{experience.summary}</p>

                  <details class="timeline-details">
                    <summary>Ver responsabilidades</summary>
                    <div class="timeline-details-body">
                      {experience.details.map((paragraph) => (
                        <p>{paragraph}</p>
                      ))}

                      {experience.stack && (
                        <p>
                          <strong>Tecnologías:</strong> {experience.stack}
                        </p>
                      )}

                      {experience.link && (
                        <p>
                          <a
                            href={experience.link.href}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            {experience.link.label}
                          </a>
                        </p>
                      )}

                      {experience.testimonial && (
                        <TestimonialAd testimonial={experience.testimonial} />
                      )}
                    </div>
                  </details>
                </div>
              </section>
            ))}
          </div>

          <h2>🌟 Una carrera orientada a la innovación</h2>
          <p>
            La trayectoria de José Antonio refleja una evolución natural desde
            el desarrollo web hasta la arquitectura de soluciones AdTech y la
            implementación de infraestructuras escalables. Su combinación de
            conocimiento técnico, visión estratégica y colaboración con grandes
            grupos mediáticos lo posiciona como un referente en la modernización
            del ecosistema publicitario español.
          </p>
        </div>

        <div class="back-link">
          <a href="/">← Volver a la portada</a>
        </div>
      </article>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .article-page {
    max-width: 800px;
    margin: 0 auto;
  }
  .featured-image {
    position: relative;
    width: 100%;
    height: 500px;
    margin-bottom: 2rem;
    overflow: hidden;
    border-radius: 8px;
  }
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .category-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--accent-primary);
    color: var(--bg-primary);
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    z-index: 2;
  }
  .full-article {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    padding: 3rem;
    border-radius: 8px;
  }
  .article-title {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0 0 1rem 0;
  }
  .article-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-primary);
    margin-bottom: 2rem;
    font-weight: 500;
    border-left: 4px solid var(--accent-primary);
    padding-left: 1.5rem;
  }
  .article-content {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }
  .article-content p {
    margin-bottom: 1.5rem;
  }
  .article-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent-primary);
    margin: 2.5rem 0 1.5rem 0;
    line-height: 1.3;
  }

  .timeline {
    position: relative;
    margin: 3rem 0;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(
      180deg,
      rgba(243, 211, 77, 0.35),
      rgba(99, 102, 241, 0.2)
    );
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 1.5rem;
    position: relative;
    margin-bottom: 3rem;
  }

  .timeline-node {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent-primary);
    box-shadow: 0 0 0 4px rgba(243, 211, 77, 0.18);
    margin-top: 1rem;
  }

  .timeline-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 1.75rem;
    backdrop-filter: blur(6px);
    box-shadow: 0 12px 32px rgba(10, 14, 23, 0.35);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(10, 14, 23, 0.45);
  }

  .timeline-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .timeline-logo-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .timeline-logo-wrapper img {
    max-width: 70%;
    max-height: 70%;
    object-fit: contain;
  }

  .timeline-heading h2 {
    font-size: 1.3rem;
    margin: 0;
    color: var(--text-primary);
  }

  .timeline-link {
    font-size: 0.9rem;
    color: var(--accent-secondary);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .timeline-link:hover {
    color: var(--accent-primary);
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .timeline-role {
    color: var(--accent-primary);
    font-weight: 600;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .timeline-period {
    font-style: italic;
  }

  .timeline-summary {
    margin: 0 0 1.5rem 0;
    color: var(--text-primary);
  }

  .timeline-details {
    border-top: 1px solid var(--border-subtle);
    padding-top: 1rem;
  }

  .timeline-details summary {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    list-style: none;
    color: var(--accent-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }

  .timeline-details summary::-webkit-details-marker {
    display: none;
  }

  .timeline-details summary::after {
    content: "+";
    margin-left: auto;
    font-size: 1.1rem;
    transition: transform 0.3s ease;
  }

  .timeline-details[open] summary::after {
    content: "−";
  }

  .timeline-details-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .timeline-details-body p {
    margin: 0;
  }

  .timeline-details-body :global(.testimonial-ad) {
    margin-top: 1rem;
  }

  .timeline-details-body :global(.testimonial-ad) p {
    margin-bottom: 0.75rem;
  }

  .article-content .timeline-card a.timeline-link {
    text-decoration: none;
  }

  .article-content .timeline-card a.timeline-link:hover {
    text-decoration: underline;
    text-decoration-thickness: 0.125rem;
  }

  .article-content a {
    color: var(--accent-primary);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: currentColor;
    text-decoration-thickness: 0.125rem;
    transition: color 0.3s ease, text-decoration-color 0.3s ease;
  }

  .article-content a:hover {
    color: var(--accent-secondary);
    text-decoration-color: currentColor;
  }
  .article-content strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .article-content em {
    color: var(--accent-secondary);
    font-style: italic;
  }
  .back-link {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
  }
  .back-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }
  .back-link a:hover {
    color: #ffffff;
    transform: translateX(-5px);
  }
  @media (max-width: 768px) {
    .container {
      padding: 1rem 0.5rem;
    }
    .featured-image {
      height: 300px;
      border-radius: 0;
    }
    .full-article {
      padding: 2rem 1.5rem;
    }
    .article-title {
      font-size: 1.8rem;
    }
    .timeline {
      padding-left: 0;
      margin: 2.5rem 0;
    }
    .timeline::before {
      left: 1rem;
    }
    .timeline-item {
      grid-template-columns: 2.2rem minmax(0, 1fr);
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .timeline-dot {
      margin-top: 0.4rem;
      width: 14px;
      height: 14px;
    }
    .timeline-card {
      padding: 1.5rem;
    }
    .timeline-card-header {
      align-items: flex-start;
    }
    .timeline-logo-wrapper {
      width: 56px;
      height: 56px;
    }
    .timeline-heading h2 {
      font-size: 1.1rem;
    }
  }
</style>
