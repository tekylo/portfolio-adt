import LogosTypescriptIcon from "../svgs/LogosTypescriptIcon.astro";
import LogosUbuntu from "../svgs/LogosUbuntu.astro";
import LogosVisualStudioCode from "../svgs/LogosVisualStudioCode.astro";
import LogosWebpack from "../svgs/LogosWebpack.astro";
