---
// Formato IAB Leaderboard: 728x90
export interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  bgGradient?: string;
}

const {
  title = "¿Necesitas un experto en AdTech?",
  subtitle = "Consultoría especializada en Google Ad Manager, Header Bidding y Programática",
  ctaText = "Contactar ahora",
  ctaLink = "mailto:lopezmolinaja@gmail.com",
  bgGradient = "linear-gradient(135deg, #6366f1, #4f46e5)",
} = Astro.props;
---

<div class="leaderboard-ad">
  <div class="ad-label">ANUNCIO</div>
  <div class="leaderboard-content">
    <div class="text-section">
      <div class="title-section">
        <h2>{title}</h2>
        <p class="subtitle">{subtitle}</p>
      </div>
    </div>
    <div class="cta-section">
      <a href={ctaLink} class="cta-button">{ctaText}</a>
    </div>
  </div>
</div>

<style>
  :root {
    --ad-bg: #232946;
    --ad-accent: #eebd3d;
    --ad-text: #fff;
    --ad-border: #121629;
    --ad-radius: 0;
    --ad-shadow: 0 4px 18px rgba(35, 41, 70, 0.18);
    --ad-box: 0 2px 8px rgba(35, 41, 70, 0.12);
    --ad-box-hover: 0 4px 16px rgba(35, 41, 70, 0.18);
    --ad-bg-light: #f3f4f6;
    --ad-border-light: #e5e7eb;
    --ad-text-dark: #222;
    --ad-text-muted: #444;
  }

  .leaderboard-ad {
    width: 728px;
    height: 90px;
    background: var(--ad-bg);
    position: relative;
    overflow: hidden;
    box-shadow: var(--ad-shadow);
    margin: 1.5rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ad-border);
    border-radius: var(--ad-radius);
  }

  .ad-label {
    position: absolute;
    top: 8px;
    right: 12px;
    background: rgba(0, 0, 0, 0.45);
    color: rgba(255, 255, 255, 0.7);
    padding: 0.22rem 0.6rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 600;
  }

  .leaderboard-content {
    display: flex;
    flex-direction: row;
    height: 100%;
    padding: 0.7rem 2rem;
    gap: 2rem;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
  }

  .text-section {
    flex: 1;
  }

  .title-section {
    margin-bottom: 0.5rem;
    text-align: left;
    background: transparent;
    padding: 0.2rem 0.7rem;
    border-radius: var(--ad-radius);
    box-shadow: none;
    color: var(--ad-bg-light);
  }

  h2 {
    font-size: 1.2rem;
    font-weight: 800;
    margin: 0 0 0.2rem 0;
    line-height: 1.1;
    letter-spacing: 0.5px;
    color: var(--ad-text);
  }

  .subtitle {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: 0.3px;
    color: var(--ad-text);
  }

  .cta-section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.7rem;
    margin-top: 0.2rem;
  }

  .cta-button {
    background: var(--ad-bg);
    color: var(--ad-accent);
    border: 2px solid var(--ad-accent);
    border-radius: var(--ad-radius);
    padding: 0.6rem 1.2rem;
    font-weight: 700;
    font-size: 0.95rem;
    box-shadow: var(--ad-box);
    transition: all 0.3s cubic-bezier(0.4, 0.8, 0.4, 1);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    letter-spacing: 0.5px;
    cursor: pointer;
  }

  .cta-button:hover {
    background: var(--ad-accent);
    color: var(--ad-bg);
    box-shadow: var(--ad-box-hover);
    transform: scale(1.05);
  }

  @media (max-width: 1024px) {
    .leaderboard-ad {
      width: 100%;
      min-height: 90px;
      height: auto;
      border-radius: 0;
      border-width: 1px;
    }
    .leaderboard-content {
      flex-direction: column;
      padding: 0.7rem;
      gap: 0.7rem;
    }
    h2 {
      font-size: 1rem;
    }
    .subtitle {
      font-size: 0.8rem;
    }
    .cta-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
