---
// Formato IAB Billboard: 970x250
export interface Props {
  headline?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  badges?: string[];
}

const {
  headline = "José Antonio López Molina",
  description = "AdTech Expert con experiencia en publicidad digital",
  ctaText = "Descargar CV",
  ctaLink = "/José Antonio López Molina · CV.pdf",
  badges = ["8+ años", "Google Ad Manager", "Header Bidding", "Xandr", "Programática"],
} = Astro.props;
---

<div class="billboard-ad">
  <span class="ad-label">Anuncio</span>
  
  <div class="billboard-content">
    <div class="billboard-text">
      <h2 class="headline">{headline}</h2>
      <p class="description">{description}</p>
      
      <div class="badges">
        {badges.map((badge) => (
          <span class="badge">{badge}</span>
        ))}
      </div>
    </div>
    
    <div class="billboard-cta">
      <a href={ctaLink} class="cta-btn" download>
        <span>{ctaText}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
  
  <div class="billboard-decor">
    <div class="accent-bar"></div>
  </div>
</div>

<style>
  .billboard-ad {
    position: relative;
    margin: var(--space-8) auto;
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition:
      border-color var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
  }

  .billboard-ad:hover {
    border-color: var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .ad-label {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--text-secondary);
    color: var(--bg-primary);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: var(--space-1) var(--space-3);
    border-radius: 0 0 0 var(--radius-md);
    z-index: 2;
    transition: background-color var(--transition-base) var(--ease-default);
  }

  .billboard-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--space-8);
    gap: var(--space-6);
    position: relative;
    z-index: 1;
  }

  .billboard-text {
    flex: 1;
  }

  .headline {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 var(--space-2) 0;
    line-height: 1.15;
    transition: color var(--transition-base) var(--ease-default);
  }

  .description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0 0 var(--space-3) 0;
    font-style: italic;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .badge {
    display: inline-block;
    background: rgba(212, 160, 23, 0.12);
    color: var(--accent-primary);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(212, 160, 23, 0.25);
    transition:
      background-color var(--transition-base) var(--ease-default),
      border-color var(--transition-base) var(--ease-default);
  }

  .badge:hover {
    background: rgba(212, 160, 23, 0.2);
    border-color: rgba(212, 160, 23, 0.4);
  }

  .billboard-cta {
    flex-shrink: 0;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--accent-primary);
    color: var(--bg-primary);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition:
      opacity var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
    white-space: nowrap;
  }

  .cta-btn:hover {
    opacity: var(--opacity-hover);
    transform: translateY(-2px);
  }

  .cta-btn svg {
    transition: transform var(--transition-base) var(--ease-default);
  }

  .cta-btn:hover svg {
    transform: translateX(3px);
  }

  .billboard-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: var(--space-1);
    height: 100%;
    background: var(--accent-primary);
  }

  /* Responsive - Tablet */
  @media (max-width: 900px) {
    .billboard-content {
      padding: var(--space-5) var(--space-6);
      gap: var(--space-4);
    }

    .headline {
      font-size: var(--text-xl);
    }
  }

  /* Responsive - Mobile */
  @media (max-width: 600px) {
    .billboard-ad {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }

    .billboard-content {
      flex-direction: column;
      padding: var(--space-5) var(--space-4);
      gap: var(--space-4);
      text-align: center;
    }

    .billboard-text {
      text-align: center;
    }

    .headline {
      font-size: var(--text-xl);
    }

    .description {
      font-size: var(--text-sm);
    }

    .badges {
      justify-content: center;
    }

    .badge {
      font-size: 0.6rem;
    }

    .billboard-cta {
      width: 100%;
    }

    .cta-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>