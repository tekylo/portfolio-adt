---
// Formato IAB Leaderboard: 728x90
export interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  bgGradient?: string;
}

const {
  title = "¿Necesitas un experto en AdTech?",
  subtitle = "Consultoría especializada en Google Ad Manager, Header Bidding y Programática",
  ctaText = "Contactar ahora",
  ctaLink = "mailto:lopezmolinaja@gmail.com",
  bgGradient = "linear-gradient(135deg, #6366f1, #4f46e5)",
} = Astro.props;
---

<div class="leaderboard-ad">
  <div class="ad-label">ANUNCIO</div>
  <div class="accent-line"></div>
  <div class="leaderboard-content">
    <div class="text-section">
      <h2>{title}</h2>
      <p class="subtitle">{subtitle}</p>
    </div>
    <a href={ctaLink} class="cta-button">{ctaText}</a>
  </div>
</div>

<style>
  .leaderboard-ad {
    width: 728px;
    height: 90px;
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    margin: var(--space-6) auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    transition:
      border-color var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default);
  }

  .leaderboard-ad:hover {
    border-color: var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .ad-label {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--text-secondary);
    color: var(--bg-primary);
    padding: 0.28rem 0.55rem;
    font-size: 0.52rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    border-radius: 0 0 0 var(--radius-sm);
    z-index: 2;
  }

  .accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent-primary);
  }

  .leaderboard-content {
    display: flex;
    flex-direction: row;
    height: 100%;
    padding: 0 var(--space-8) 0 var(--space-5);
    gap: var(--space-6);
    align-items: center;
    justify-content: space-between;
    width: 100%;
    position: relative;
  }

  .text-section {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    margin: 0;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .subtitle {
    font-size: var(--text-sm);
    font-weight: 400;
    margin: 0;
    color: var(--text-secondary);
    opacity: 0.9;
  }

  .cta-button {
    background: var(--accent-primary);
    color: var(--bg-primary);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
    font-weight: 600;
    font-size: var(--text-sm);
    box-shadow: var(--shadow-sm);
    transition:
      opacity var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
    cursor: pointer;
    flex-shrink: 0;
  }

  .cta-button:hover {
    opacity: var(--opacity-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 1024px) {
    .leaderboard-ad {
      width: 100%;
      min-height: 90px;
      height: auto;
      border-radius: 0;
      border-width: 1px;
    }

    .leaderboard-content {
      flex-direction: column;
      padding: var(--space-3) var(--space-4);
      gap: var(--space-3);
      text-align: center;
    }

    .text-section {
      align-items: center;
    }

    h2 {
      font-size: var(--text-lg);
    }

    .subtitle {
      font-size: var(--text-xs);
    }

    .cta-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
