---
import Layout from "../layouts/Layout.astro";
import NavMenu from "../components/NavMenu.astro";
import NewspaperHeader from "../components/NewspaperHeader.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import articles from "../data/articles.json";
const article = articles.find((a) => a.slug === "proyectos");
const data = article!;
const formatDate = (date: Date) => new Intl.DateTimeFormat("es-ES", { day: "numeric", month: "long", year: "numeric" }).format(date);
const today = formatDate(new Date());

const projects = [
  {
    company: "Madrid Destino",
    subtitle: "Ecosistema Digital: Web + Marketing",
    summary:
      "Contrato de consultoría con la empresa Alkemy para la conceptualización, desarrollo e implementación del ecosistema digital del Ayuntamiento de Madrid: entorno web y herramientas de marketing digital.",
    site: "https://www.madrid-destino.com/",
    siteLabel: "madrid-destino.com",
    logo: "/logos/madrid-destino.jpg",
    stack: [
      "Consultoría técnica",
      "Ecosistema digital",
      "Marketing digital",
      "Entorno web",
    ],
    ctaLabel: "Visitar site",
  },
  {
    company: "Vocento",
    subtitle: "Migración de AdServer, WPO y Paywall",
    summary:
      "Migración de Google Ad Manager a Equativ (Smart AdServer) y rollback posterior para alinear estrategia, con soporte al paywall editorial y mejoras de rendimiento en la librería publicitaria.",
    site: "https://www.vocento.com/",
    siteLabel: "vocento.com",
    logo: "/logos/vocento.png",
    stack: [
      "Google Ad Manager",
      "Equativ",
      "JavaScript",
      "React",
      "Symfony",
      "MySQL",
      "MongoDB",
    ],
    ctaLabel: "Visitar site",
  },
  {
    company: "Arkeero",
    subtitle: "Librería publicitaria unificada",
    summary:
      "Desarrollo de una librería transversal junto a David Berrocal integrando Prebid.js y gestionando la migración programática a Xandr.",
    site: "https://arkeero.com/",
    siteLabel: "arkeero.com",
    logo: "/logos/arkeero.jpeg",
    stack: [
      "JavaScript",
      "TypeScript",
      "React",
      "Node.js",
      "MongoDB",
      "Xandr",
      "Google Ad Manager",
    ],
    ctaLabel: "Visitar site",
  },
  {
    company: "Emprendedores",
    subtitle: "AdTech y segmentación",
    summary:
      "Diseño de la estrategia de segmentación y la integración publicitaria para la revista líder en economía de empresa.",
    site: "https://emprendedores.es/",
    siteLabel: "emprendedores.es",
    logo: "/logos/emprendedores.png",
    fallback: "E",
    stack: ["Google Ad Manager", "Tagging", "Analítica"],
    ctaLabel: "Visitar site",
  },
  {
    company: "Carmen Reina",
    subtitle: "Portfolio artístico y tienda online",
    summary:
      "Diseño y personalización del sitio oficial de la artista Carmen Reina, combinando galería, narrativa personal y catálogo de obra en una experiencia inmersiva.",
    site: "https://www.carmenreina.com/",
    siteLabel: "carmenreina.com",
    logo: "/logos/carmenreina.png",
    stack: ["Format", "Dirección de arte", "SEO básico"],
    ctaLabel: "Visitar site",
  },
  {
    company: "Axel Springer",
    subtitle: "Integración publicitaria global",
    summary:
      "Creación de una librería de anuncios para el grupo, alineando despliegues con su ecosistema programático internacional.",
    site: "https://www.axelspringer.com/en/",
    siteLabel: "axelspringer.com",
    logo: "/logos/axelspringer-integrar-publicidad.png",
    stack: ["Google Ad Manager", "JavaScript"],
    ctaLabel: "Visitar site",
  },
  {
    company: "Colegio Pablo VI",
    subtitle: "Desarrollo web a medida",
    summary:
      "Diseño y desarrollo del sitio oficial con énfasis en experiencia de usuario y contenidos dinámicos.",
    site: "https://www.pablovi.es/",
    siteLabel: "pablovi.es",
    logo: "/logos/colegio-pablo-vi.png",
    stack: ["HTML", "CSS", "JavaScript"],
    ctaLabel: "Visitar site",
  },
  {
    company: "Clínica Henares",
    subtitle: "Sitio corporativo sanitario",
    summary:
      "Desarrollo web con diseño moderno, SEO y solicitudes de cita online para mejorar la captación de pacientes.",
    site: "https://clinicahenares.com/",
    siteLabel: "clinicahenares.com",
    logo: "/logos/clinica-henares.png",
    stack: ["WordPress (PHP)", "HTML", "CSS"],
    ctaLabel: "Visitar site",
  },
  {
    company: "Samarkha Life Iglesias",
    subtitle: "Web profesional de psicología",
    summary:
      "Sitio WordPress con identidad de marca y SEO on-page pensado para profesionales de la psicología.",
    site: "https://samarkhalifeiglesias.com/",
    siteLabel: "samarkhalifeiglesias.com",
    logo: "/logos/samar.png",
    fallback: "S",
    stack: ["WordPress (PHP)", "HTML", "CSS", "SEO"],
    ctaLabel: "Visitar site",
  },
  {
    company: "TopComparativas",
    subtitle: "Plataforma de análisis",
    summary:
      "Desarrollo de un site de comparativas con SEO avanzado, filtros dinámicos y ordenación inteligente.",
    site: "https://www.topcomparativas.com/",
    siteLabel: "topcomparativas.com",
    logo: "/logos/top-comparativas.svg",
    stack: ["WordPress", "SEO avanzado"],
    ctaLabel: "Visitar site",
  },
  {
    company: "Web Centros Médicos",
    subtitle: "Portal multiservicio",
    summary:
      "Centralización de información y herramientas interactivas como citas y localización para un centro médico.",
    site: "https://mdhcentros.es/",
    siteLabel: "mdhcentros.es",
    logo: "/logos/centros-medicos-mdh.png",
    stack: ["WordPress", "SEO", "UX"],
    ctaLabel: "Visitar site",
  },
  {
    company: "Néfele",
    subtitle: "Plataforma de predicción meteorológica",
    summary:
      "Aplicación web para la Universidad de Jaén que analiza predicciones meteorológicas mediante algoritmos de regresión con pronósticos de 24 y 48 horas.",
    site: "https://simidat-apps.ujaen.es/nefele/#/Nefele",
    siteLabel: "ujaen.es/nefele",
    logo: "/logos/ujaen.jpg",
    stack: ["AngularJS", "Python", "R"],
    ctaLabel: "Visitar site",
  },
];
---

<Layout title="Proyectos | El Diario AdTech">
  <div class="container">
    <NewspaperHeader />
  </div>
  <NavMenu />

  <div class="container">
    <Breadcrumbs
      items={[{ label: "Portada", href: "/" }, { label: "Proyectos" }]}
    />
  </div>

  <div class="container">
    <div class="article-page">
      <div class="featured-image">
        <img
          src={data.imageUrl}
          alt={data.title}
          transition:name="article-/articulo-proyectos"
        />
        <span class="category-badge">{data.category}</span>
      </div>

      <article class="full-article">
        <h1 class="article-title" transition:name="title-/articulo-proyectos">
          {data.title}
        </h1>

        <div class="article-meta">
          <span class="date">{today}</span>
          <span class="separator">|</span>
          <span class="author">{data.author}</span>
        </div>

        <p class="lead">
          {data.subtitle}
        </p>

        <div class="article-content">
          <p>
            A lo largo de su trayectoria, José Antonio López Molina ha combinado
            arquitectura AdTech y desarrollo web en proyectos para grupos de
            medios, publishers y negocios independientes. Esta selección refleja
            ese recorrido multidisciplinar.
          </p>

          <p>
            📌 Cada iniciativa pone en juego branding, rendimiento y negocio,
            conectando stakeholders y tecnología con una misma hoja de ruta.
          </p>

          <div class="projects-accordion">
            {projects.map((project, index) => (
              <details class="project-panel">
                <summary>
                  <div
                    class={`panel-logo ${project.logo ? "" : "panel-logo--fallback"}`}
                  >
                    {project.logo ? (
                      <img
                        src={project.logo}
                        alt={`Logo de ${project.company}`}
                        loading="lazy"
                      />
                    ) : (
                      <span aria-hidden="true">
                        {project.fallback ?? project.company.charAt(0)}
                      </span>
                    )}
                  </div>

                  <div class="panel-heading">
                    <h3>{project.company}</h3>
                    <p>{project.subtitle}</p>
                  </div>

                  <div class="panel-indicator" aria-hidden="true">
                    <span />
                  </div>
                </summary>

                <div class="panel-content">
                  <div class="panel-description">
                    <p>{project.summary}</p>
                  </div>

                  <div class="panel-stack">
                    {project.stack.map((tech) => (
                      <span>{tech}</span>
                    ))}
                  </div>

                  <a
                    href={project.site}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="panel-cta"
                  >
                    {project.ctaLabel}
                  </a>
                </div>
              </details>
            ))}
          </div>

          <p>
            🌟 Cada uno de estos proyectos conecta estrategia, datos y ejecución
            técnica para transformar ideas en resultados medibles dentro del
            ecosistema AdTech y digital.
          </p>
        </div>

        <div class="back-link">
          <a href="/">← Volver a la portada</a>
        </div>
      </article>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .article-page {
    max-width: 800px;
    margin: 0 auto;
  }
  .featured-image {
    position: relative;
    width: 100%;
    height: 500px;
    margin-bottom: 2rem;
    overflow: hidden;
    border-radius: 8px;
  }
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .category-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--accent-primary);
    color: var(--bg-primary);
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    z-index: 2;
  }
  .full-article {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    padding: 3rem;
    border-radius: 8px;
  }
  .article-title {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0 0 1rem 0;
  }
  .article-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-primary);
    margin-bottom: 2rem;
    font-weight: 500;
    border-left: 4px solid var(--accent-primary);
    padding-left: 1.5rem;
  }
  .article-content {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }
  .article-content p {
    margin-bottom: 1.5rem;
  }
  .article-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent-primary);
    margin: 2.5rem 0 1.5rem 0;
    line-height: 1.3;
  }

  .article-content a {
    color: var(--accent-primary);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: currentColor;
    text-decoration-thickness: 0.125rem;
    transition:
      color 0.3s ease,
      text-decoration-color 0.3s ease;
  }

  .article-content a:hover {
    color: var(--accent-secondary);
    text-decoration-color: currentColor;
  }

  .article-content em {
    color: var(--accent-secondary);
    font-style: italic;
  }

  .projects-accordion {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin-top: 2.5rem;
  }

  .project-panel {
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(135deg, rgba(18, 23, 34, 0.95), rgba(11, 15, 24, 0.8));
    box-shadow: 0 18px 55px rgba(6, 10, 20, 0.55);
    overflow: hidden;
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
  }

  .project-panel[open] {
    border-color: rgba(243, 211, 77, 0.45);
    box-shadow: 0 24px 68px rgba(8, 12, 24, 0.65);
  }

  .project-panel summary {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    padding: 1.9rem 2.2rem;
    cursor: pointer;
    list-style: none;
  }

  .project-panel summary::-webkit-details-marker {
    display: none;
  }

  .panel-logo {
    flex: 0 0 auto;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem;
    border-radius: 18px;
    background: linear-gradient(135deg, #e8e9ea 0%, #d1d2d4 100%);
    border: 1px solid rgba(0, 0, 0, 0.12);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .panel-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: brightness(0.95);
  }

  .panel-logo--fallback {
    border-radius: 18px;
    background: linear-gradient(135deg, #e8e9ea 0%, #d1d2d4 100%);
    border: 1px solid rgba(0, 0, 0, 0.12);
    color: rgba(0, 0, 0, 0.7);
    font-weight: 700;
    font-size: 1.45rem;
    text-transform: uppercase;
  }

  @media (prefers-color-scheme: dark) {
    .panel-logo {
      background: linear-gradient(135deg, #1e2028 0%, #15161c 100%);
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }
    .panel-logo img {
      filter: brightness(1);
    }
    .panel-logo--fallback {
      background: linear-gradient(135deg, #1e2028 0%, #15161c 100%);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.9);
    }
  }

  .panel-heading {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .panel-heading h3 {
    margin: 0;
    color: var(--text-primary);
    font-size: 1.4rem;
    letter-spacing: 0.4px;
  }

  .panel-heading p {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
  }

  .panel-indicator {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.35s ease, transform 0.35s ease;
  }

  .panel-indicator span {
    position: relative;
    width: 12px;
    height: 2px;
    background: rgba(255, 255, 255, 0.9);
  }

  .panel-indicator span::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 12px;
    height: 2px;
    background: rgba(255, 255, 255, 0.9);
    transform: rotate(90deg);
    transition: transform 0.35s ease;
  }

  .project-panel[open] .panel-indicator {
    border-color: rgba(243, 211, 77, 0.45);
    transform: rotate(90deg);
  }

  .project-panel[open] .panel-indicator span::after {
    transform: rotate(0deg);
  }

  .panel-content {
    padding: 0 2.2rem;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition:
      max-height 0.45s ease,
      opacity 0.35s ease,
      padding 0.3s ease;
  }

  .project-panel[open] .panel-content {
    padding: 0 2.2rem 2rem;
    max-height: 650px;
    opacity: 1;
  }

  .panel-description p {
    margin: 0;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.65;
    padding-bottom: 1.25rem;
  }

  .panel-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
  }

  .panel-stack span {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.82rem;
    letter-spacing: 0.2px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition:
      background 0.25s ease,
      border-color 0.25s ease;
  }

  .panel-stack span:hover {
    background: rgba(99, 102, 241, 0.22);
    border-color: rgba(243, 211, 77, 0.35);
  }

  .panel-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--accent-primary);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
    letter-spacing: 0.4px;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .panel-cta::after {
    content: "→";
    font-size: 1rem;
    transition: transform 0.3s ease;
  }

  .panel-cta:hover {
    color: var(--accent-secondary);
    transform: translateX(4px);
  }

  .panel-cta:hover::after {
    transform: translateX(3px);
  }

  .back-link {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }
  .back-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }
  .back-link a:hover {
    color: var(--text-primary);
    transform: translateX(-5px);
  }
  @media (max-width: 768px) {
    .container {
      padding: 1rem 0.5rem;
    }
    .featured-image {
      height: 300px;
      border-radius: 0;
    }
    .full-article {
      padding: 2rem 1.5rem;
    }
    .article-title {
      font-size: 1.8rem;
    }
    .projects-accordion {
      gap: 1.5rem;
    }
    .project-panel summary {
      padding: 1.45rem 1.5rem;
      gap: 1.1rem;
    }
    .panel-logo {
      width: 60px;
      height: 60px;
      border-radius: 14px;
      background: linear-gradient(135deg, #e8e9ea 0%, #d1d2d4 100%);
      border: 1px solid rgba(0, 0, 0, 0.12);
    }
    .panel-logo--fallback {
      font-size: 1.15rem;
      background: linear-gradient(135deg, #e8e9ea 0%, #d1d2d4 100%);
      border: 1px solid rgba(0, 0, 0, 0.12);
      color: rgba(0, 0, 0, 0.7);
    }
    .panel-heading h3 {
      font-size: 1.2rem;
    }
    .panel-heading p {
      font-size: 0.9rem;
    }
    .panel-content {
      padding: 0 1.5rem;
    }
    .project-panel[open] .panel-content {
      padding: 0 1.5rem 1.4rem;
    }
  }

  @media (max-width: 768px) and (prefers-color-scheme: dark) {
    .panel-logo {
      background: linear-gradient(135deg, #1e2028 0%, #15161c 100%);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .panel-logo--fallback {
      background: linear-gradient(135deg, #1e2028 0%, #15161c 100%);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.9);
    }
  }
</style>
