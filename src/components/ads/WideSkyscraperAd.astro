---
// Formato IAB Wide Skyscraper: 160x600
export interface Props {
  title?: string;
  items?: string[];
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = "Servicios AdTech",
  items = [
    "Google Ad Manager",
    "Header Bidding",
    "Programática",
    "SSP/DSP Integration",
    "Revenue Optimization",
    "Tag Management",
  ],
  ctaText = "Consultar",
  ctaLink = "mailto:lopezmolinaja@gmail.com",
} = Astro.props;
---

<div class="wide-skyscraper-ad">
  <div class="ad-label">ANUNCIO</div>
  <div class="accent-line"></div>

  <div class="ad-content">
    <div class="header-icon">
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
        <path d="M2 17l10 5 10-5"></path>
        <path d="M2 12l10 5 10-5"></path>
      </svg>
    </div>

    <h3>{title}</h3>

    <ul class="services-list">
      {
        items.map((item) => (
          <li>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>{item}</span>
          </li>
        ))
      }
    </ul>

    <a href={ctaLink} class="cta-button">
      {ctaText}
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</div>

<style>
  .wide-skyscraper-ad {
    width: 160px;
    height: 600px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition:
      transform var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default),
      border-color var(--transition-base) var(--ease-default);
  }

  .wide-skyscraper-ad:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent-primary);
  }

  .ad-label {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background-color: rgba(0, 0, 0, 0.35);
    color: rgba(255, 255, 255, 0.7);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 2;
  }

  .accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent-primary);
  }

  .ad-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-5) var(--space-3) var(--space-4) var(--space-4);
    height: 100%;
  }

  .header-icon {
    width: 44px;
    height: 44px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-3);
    color: var(--accent-primary);
  }

  h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 var(--space-4) 0;
    text-align: left;
    line-height: 1.25;
    font-family: var(--font-display);
    align-self: stretch;
  }

  .services-list {
    list-style: none;
    padding: 0;
    margin: 0 0 auto 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .services-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: 0.75rem;
    color: var(--text-primary);
    line-height: 1.4;
    padding: var(--space-2) 0;
    border-top: 1px solid var(--border-subtle);
  }

  .services-list li svg {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--accent-primary);
  }

  .services-list li span {
    flex: 1;
    opacity: 0.92;
  }

  .cta-button {
    background: var(--accent-primary);
    color: var(--bg-primary);
    padding: var(--space-3) var(--space-3);
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.8rem;
    text-decoration: none;
    transition:
      opacity var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    width: 100%;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }

  .cta-button:hover {
    opacity: var(--opacity-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .cta-button svg {
    transition: transform var(--transition-base) var(--ease-default);
  }

  .cta-button:hover svg {
    transform: translateX(2px);
  }
</style>
