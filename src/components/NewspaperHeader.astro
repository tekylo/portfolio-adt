---
import ThemeToggle from "./ThemeToggle.astro";
// Cabecera estilo periódico
---

<header class="newspaper-header">
  <div class="newspaper-banner">
    <div class="banner-top">
      <span class="date">
        {
          new Date().toLocaleDateString("es-ES", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </span>
      <ThemeToggle />
    </div>
    <a href="/" class="title-link">
      <h1 class="newspaper-title">EL DIARIO ADTECH</h1>
    </a>
    <p class="newspaper-slogan">
      Innovación Publicitaria · Tecnología Digital · Soluciones Programáticas
    </p>
    <div class="divider"></div>
  </div>
</header>

<style>
  .newspaper-header {
    max-width: 1200px;
    border-bottom: 3px double var(--accent-primary);
    width: 100%;
    transition:
      border-color var(--transition-base) var(--ease-default);
  }

  .newspaper-banner {
    text-align: center;
  }

  .banner-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    margin-bottom: var(--space-2);
    padding: var(--space-1) 0;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-body);
  }

  .date {
    color: var(--text-secondary);
    text-transform: capitalize;
    font-weight: 600;
    letter-spacing: 0.05rem;
    transition: color var(--transition-base) var(--ease-default);
  }

  .title-link {
    text-decoration: none;
    display: inline-block;
    transition: transform var(--transition-base) var(--ease-default);
  }

  .title-link:hover {
    transform: scale(1.02);
  }

  .newspaper-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: bold;
    margin: var(--space-4) 0 var(--space-2) 0;
    letter-spacing: 2px;
    color: var(--text-primary);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    transition: color var(--transition-base) var(--ease-default);
  }

  .title-link:hover .newspaper-title {
    color: var(--accent-primary);
  }

  .newspaper-slogan {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin: 0;
    letter-spacing: 0.5px;
  }

  .divider {
    height: 2px;
    background: linear-gradient(
      to right,
      transparent,
      var(--accent-primary),
      transparent
    );
    margin: var(--space-4) auto;
    max-width: 600px;
    transition: background var(--transition-base) var(--ease-default);
  }

  @media (max-width: 768px) {
    .newspaper-header {
      padding: var(--space-3) var(--space-4);
    }

    .banner-top {
      flex-direction: column;
      align-items: center;
      font-size: 0.7rem;
      gap: var(--space-2);
    }

    .newspaper-title {
      letter-spacing: 1px;
    }

    .newspaper-slogan {
      font-size: var(--text-sm);
    }
  }
</style>
