---
// Formato IAB Leaderboard: 728x90
export interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  bgGradient?: string;
}

const {
  title = "¿Necesitas un experto en AdTech?",
  subtitle = "Consultoría especializada en Google Ad Manager, Header Bidding y Programática",
  ctaText = "Contactar ahora",
  ctaLink = "mailto:lopezmolinaja@gmail.com",
  bgGradient = "linear-gradient(135deg, #6366f1, #4f46e5)",
} = Astro.props;
---

<div class="leaderboard-ad">
  <div class="ad-label">ANUNCIO</div>
  <div class="leaderboard-content">
    <div class="text-section">
      <div class="title-section">
        <h2>{title}</h2>
        <p class="subtitle">{subtitle}</p>
      </div>
    </div>
    <div class="cta-section">
      <a href={ctaLink} class="cta-button">{ctaText}</a>
    </div>
  </div>
</div>

<style>
  .leaderboard-ad {
    width: 728px;
    height: 90px;
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    margin: var(--space-6) auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    transition:
      border-color var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default);
  }

  .leaderboard-ad:hover {
    border-color: var(--border-default);
    box-shadow: var(--shadow-md);
  }

  .ad-label {
    position: absolute;
    top: 8px;
    right: 12px;
    background: rgba(0, 0, 0, 0.45);
    color: rgba(255, 255, 255, 0.7);
    padding: 0.22rem 0.6rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 600;
  }

  .leaderboard-content {
    display: flex;
    flex-direction: row;
    height: 100%;
    padding: 0.7rem 2rem;
    gap: 2rem;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
  }

  .text-section {
    flex: 1;
  }

  .title-section {
    margin-bottom: var(--space-2);
    text-align: left;
    background: transparent;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    box-shadow: none;
    color: var(--text-primary);
  }

  h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    margin: 0 0 var(--space-1) 0;
    line-height: 1.1;
    letter-spacing: 0.5px;
    color: var(--text-primary);
  }

  .subtitle {
    font-size: var(--text-sm);
    font-weight: 600;
    margin: 0;
    letter-spacing: 0.3px;
    color: var(--text-secondary);
  }

  .cta-section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.7rem;
    margin-top: 0.2rem;
  }

.cta-button {
    background: transparent;
    color: var(--accent-primary);
    border: 2px solid var(--accent-primary);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-5);
    font-weight: 700;
    font-size: var(--text-sm);
    box-shadow: var(--shadow-sm);
    transition:
      background-color var(--transition-base) var(--ease-default),
      color var(--transition-base) var(--ease-default),
      box-shadow var(--transition-base) var(--ease-default),
      transform var(--transition-base) var(--ease-default);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
    letter-spacing: 0.5px;
    cursor: pointer;
  }

  .cta-button:hover {
    background: var(--accent-primary);
    color: var(--bg-primary);
    box-shadow: var(--shadow-md);
    transform: scale(1.05);
  }

  .cta-button:hover {
    background: var(--ad-accent);
    color: var(--ad-bg);
    box-shadow: var(--ad-box-hover);
    transform: scale(1.05);
  }

  @media (max-width: 1024px) {
    .leaderboard-ad {
      width: 100%;
      min-height: 90px;
      height: auto;
      border-radius: 0;
      border-width: 1px;
    }
    .leaderboard-content {
      flex-direction: column;
      padding: 0.7rem;
      gap: 0.7rem;
    }
    h2 {
      font-size: 1rem;
    }
    .subtitle {
      font-size: 0.8rem;
    }
    .cta-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
