---
// Componente para artículos de portada estilo El País
export interface Props {
  title: string;
  subtitle: string;
  category: string;
  imageUrl: string;
  href: string;
  author?: string;
  size?: "large" | "medium" | "small"; // large = columna completa, medium = media columna, small = miniatura
  prominence?: "hero" | "secondary" | "brief";
}

const sizeToProminence = {
  large: "hero",
  medium: "secondary",
  small: "brief",
} as const;

const {
  title,
  subtitle,
  category,
  imageUrl,
  href,
  author,
  size = "large",
  prominence,
} = Astro.props;

const resolvedProminence = prominence ?? sizeToProminence[size];
---

<article class={`frontpage-article prominence-${resolvedProminence}`}>
  <a href={href} class="article-link">
    <div class="article-image">
      <img src={imageUrl} alt={title} transition:name={`article-${href}`} />
      <span class="category-badge">{category}</span>
    </div>
    <div class="article-content">
      <h2 class="article-title" transition:name={`title-${href}`}>{title}</h2>
      <p class="article-subtitle">{subtitle}</p>
      {author && <p class="article-author">{author}</p>}
    </div>
  </a>
</article>

<style>
  .frontpage-article {
    position: relative;
    border: 1px solid var(--border-subtle);
    background: var(--bg-secondary);
    overflow: hidden;
    transition: all 0.3s ease;
    min-height: 100%;
  }

  .frontpage-article:hover {
    border-color: var(--accent-primary);
    box-shadow: 0 4px 20px rgba(243, 211, 77, 0.15);
    transform: translateY(-2px);
  }

  .frontpage-article.prominence-hero {
    min-height: clamp(32rem, 54vw, 46rem);
  }

  .frontpage-article.prominence-secondary {
    min-height: clamp(18rem, 26vw, 23rem);
  }

  .frontpage-article.prominence-brief {
    min-height: clamp(14rem, 20vw, 17rem);
  }

  .article-link {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .article-image {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .prominence-hero .article-image {
    aspect-ratio: 4 / 3;
  }

  .prominence-secondary .article-image {
    aspect-ratio: 16 / 10;
  }

  .prominence-brief .article-image {
    aspect-ratio: 16 / 9;
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .frontpage-article:hover .article-image img {
    transform: scale(1.05);
  }

  .category-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--accent-primary);
    color: var(--bg-primary);
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    z-index: 2;
  }

  .article-content {
    padding: 1.35rem 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .prominence-secondary .article-content {
    padding: 1rem 1.05rem 1.15rem;
    gap: 0.55rem;
  }

  .prominence-brief .article-content {
    padding: 0.85rem 0.95rem 1rem;
    gap: 0.35rem;
  }

  .article-title {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.12;
    margin: 0;
    color: var(--text-primary);
    transition: color 0.3s ease;
    text-wrap: balance;
  }

  .prominence-hero .article-title {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .prominence-secondary .article-title {
    font-size: clamp(1.35rem, 1.75vw, 1.8rem);
  }

  .prominence-brief .article-title {
    font-size: clamp(1rem, 1.15vw, 1.25rem);
    line-height: 1.2;
  }

  .frontpage-article:hover .article-title {
    color: var(--accent-primary);
  }

  .article-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.45;
  }

  .prominence-hero .article-subtitle {
    font-size: 1.05rem;
    -webkit-line-clamp: 4;
  }

  .prominence-secondary .article-subtitle {
    font-size: 0.92rem;
    -webkit-line-clamp: 2;
  }

  .prominence-brief .article-subtitle {
    font-size: 0.82rem;
    -webkit-line-clamp: 2;
  }

  .article-author {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: auto;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .frontpage-article.prominence-hero {
      min-height: clamp(28rem, 62vw, 38rem);
    }

    .frontpage-article.prominence-secondary {
      min-height: clamp(17rem, 28vw, 21rem);
    }

    .frontpage-article.prominence-brief {
      min-height: clamp(13rem, 22vw, 16rem);
    }

    .prominence-hero .article-title {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
    }
  }

  @media (max-width: 768px) {
    .frontpage-article.prominence-hero,
    .frontpage-article.prominence-secondary,
    .frontpage-article.prominence-brief {
      min-height: auto;
    }

    .prominence-hero .article-image {
      aspect-ratio: 16 / 10;
    }

    .prominence-secondary .article-image,
    .prominence-brief .article-image {
      aspect-ratio: 16 / 9;
    }

    .article-content {
      padding: 1rem 1rem 1.15rem;
    }

    .prominence-brief .article-content {
      padding: 0.95rem 1rem 1.05rem;
    }

    .prominence-hero .article-title {
      font-size: 1.85rem;
    }

    .prominence-secondary .article-title {
      font-size: 1.35rem;
    }

    .prominence-brief .article-title {
      font-size: 1.05rem;
    }

    .article-subtitle {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .article-content {
      padding: 0.9rem 0.9rem 1rem;
    }

    .prominence-hero .article-title {
      font-size: 1.6rem;
    }

    .prominence-secondary .article-title {
      font-size: 1.2rem;
    }

    .prominence-brief .article-title {
      font-size: 1rem;
    }

    .article-subtitle {
      font-size: 0.84rem;
      -webkit-line-clamp: 2;
    }
  }
</style>
