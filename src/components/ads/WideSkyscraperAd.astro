---
// Formato IAB Wide Skyscraper: 160x600
export interface Props {
  title?: string;
  items?: string[];
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = "Servicios AdTech",
  items = [
    "Google Ad Manager",
    "Header Bidding",
    "Programática",
    "SSP/DSP Integration",
    "Revenue Optimization",
    "Tag Management",
  ],
  ctaText = "Consultar",
  ctaLink = "mailto:lopezmolinaja@gmail.com",
} = Astro.props;
---

<div class="wide-skyscraper-ad">
  <div class="ad-label">Ad</div>

  <div class="ad-content">
    <div class="header-icon">
      <svg
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
        <path d="M2 17l10 5 10-5"></path>
        <path d="M2 12l10 5 10-5"></path>
      </svg>
    </div>

    <h3>{title}</h3>

    <ul class="services-list">
      {
        items.map((item) => (
          <li>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>{item}</span>
          </li>
        ))
      }
    </ul>

    <a href={ctaLink} class="cta-button">
      {ctaText}
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</div>

<style>
  .wide-skyscraper-ad {
    width: 160px;
    height: 600px;
    background: linear-gradient(
      180deg,
      rgba(74, 144, 226, 0.15),
      rgba(138, 43, 226, 0.15)
    );
    border: 2px solid rgba(225, 188, 38, 0.3);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
  }

  .wide-skyscraper-ad:hover {
    box-shadow: 0 8px 25px rgba(225, 188, 38, 0.4);
    border-color: rgba(225, 188, 38, 0.5);
  }

  .ad-label {
    position: absolute;
    top: 8px;
    right: 8px;
    background-color: rgba(0, 0, 0, 0.5);
    color: rgba(255, 255, 255, 0.7);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.55rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ad-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
    height: 100%;
  }

  .header-icon {
    width: 60px;
    height: 60px;
    background: rgba(225, 188, 38, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: #e1bc26;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: bold;
    color: #ffffff;
    margin: 0 0 1.25rem 0;
    text-align: center;
    line-height: 1.3;
  }

  .services-list {
    list-style: none;
    padding: 0;
    margin: 0 0 auto 0;
    width: 100%;
  }

  .services-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.3;
  }

  .services-list li svg {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--accent-secondary);
  }

  .services-list li span {
    flex: 1;
  }

  .cta-button {
    background: #e1bc26;
    color: #1a1a1a;
    padding: 0.6rem 1rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    width: 100%;
    justify-content: center;
  }

  .cta-button:hover {
    background: #ffd700;
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(225, 188, 38, 0.5);
  }

  .cta-button svg {
    transition: transform 0.3s ease;
  }

  .cta-button:hover svg {
    transform: translateX(2px);
  }
</style>
