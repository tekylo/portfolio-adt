---
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
}

const { title } = Astro.props;
const siteUrl = "https://jalopezmolina.vercel.app";
const pageTitle = title;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Portfolio de José Antonio López Molina - AdTech Expert & Full Stack Developer especializado en tecnologías publicitarias y desarrollo web moderno."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={siteUrl} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content="Portfolio de José Antonio - AdTech Expert & Full Stack Developer" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="José Antonio - AdTech Portfolio" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content="Portfolio de José Antonio - AdTech Expert & Full Stack Developer" />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:site" content="@tekylo" />
    
    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    
    <title>{title}</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
    <ViewTransitions />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "José Antonio López Molina",
      "jobTitle": "AdTech Expert & Full Stack Developer",
      "url": "https://jalopezmolina.vercel.app",
      "sameAs": [
        "https://github.com/tekylo",
        "https://www.linkedin.com/in/jos%C3%A9-antonio-lopez-molina-9881a8aa/",
        "https://twitter.com/tekylo"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Wemass"
      },
      "knowsAbout": ["AdTech", "Full Stack Development", "JavaScript", "TypeScript", "React", "Vue", "Node.js", "Go"]
    }
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      // Función para aplicar el tema
      function updateThemeToggleButton(theme) {
        const button = document.getElementById("themeToggle");
        if (!button) return;
        const nextTheme = theme === "dark" ? "light" : "dark";
        button.setAttribute("data-next-theme", nextTheme);
        button.setAttribute(
          "aria-label",
          `Cambiar a modo ${nextTheme === "dark" ? "oscuro" : "claro"}`
        );
      }

      function applyTheme() {
        const theme = (() => {
          if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
          ) {
            return localStorage.getItem("theme");
          }
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
          }
          return "dark"; // Por defecto dark
        })();

        if (theme === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }

        window.localStorage.setItem("theme", theme);
        updateThemeToggleButton(theme);
      }

      const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        const theme = isDark ? "dark" : "light";
        localStorage.setItem("theme", theme);
        updateThemeToggleButton(theme);
      };

      // Función para configurar el event listener del botón
      function setupThemeToggle() {
        const button = document.getElementById("themeToggle");
        if (button) {
          button.removeEventListener("click", handleToggleClick);
          button.addEventListener("click", handleToggleClick);
        }
      }

      // Aplicar tema y configurar botón inmediatamente
      applyTheme();
      setupThemeToggle();

      // Reaplica el tema y reconfigura el botón después de cada navegación con View Transitions
      document.addEventListener("astro:after-swap", () => {
        applyTheme();
        setupThemeToggle();
      });

      // También configurar en DOMContentLoaded por si acaso
      document.addEventListener("DOMContentLoaded", () => {
        applyTheme();
        setupThemeToggle();
      });
    </script>
  </body>
</html>
<style is:global>
  :root {
    /* ═══════════════════════════════════════════════════════════
       LINEAR DESIGN SYSTEM — Portfolio
       Base: 4px unit | Transitions: 150ms | Linear aesthetics
    ═══════════════════════════════════════════════════════════ */

    /* ─── Light Mode — Backgrounds ─── */
    --bg-primary: #ffffff;
    --bg-secondary: #f8f9fa;
    --bg-tertiary: #f1f3f5;

    /* ─── Light Mode — Text ─── */
    --text-primary: #1a1d23;
    --text-secondary: #5f6368;
    --text-tertiary: #8a8f98;

    /* ─── Light Mode — Accents ─── */
    --accent-primary: #d4a017;
    --accent-hover: #f3d34d;
    --accent-muted: #3d3820;

    /* ─── Light Mode — Borders (ultra-subtle) ─── */
    --border-subtle: rgba(0, 0, 0, 0.06);
    --border-default: rgba(0, 0, 0, 0.1);

    /* ─── Semantic States ─── */
    --success: #5ab953;
    --error: #e54d4d;
    --warning: #f59e0b;
    --info: #2563eb;

    /* ─── Legacy Compat ─── */
    --background: var(--bg-primary);
    --text-color: var(--text-primary);
    --border-medium: var(--border-default);

    /* ─── Typography ─── */
    --font-display: Georgia, "Times New Roman", serif;
    --font-body: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    --font-mono: "SF Mono", Monaco, "Lucida Console", "Liberation Mono", "DejaVu Sans Mono", "Bitstream Vera Sans Mono", "Courier New", monospace;

    /* ─── Type Scale ─── */
    --text-xs: 0.75rem;    /* 12px */
    --text-sm: 0.875rem;   /* 14px */
    --text-base: 1rem;     /* 16px */
    --text-lg: 1.125rem;   /* 18px */
    --text-xl: 1.25rem;    /* 20px */
    --text-2xl: 1.5rem;    /* 24px */
    --text-3xl: 2rem;       /* 32px */
    --text-4xl: 2.5rem;    /* 40px */

    /* ─── Spacing Scale (4px base) ─── */
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 20px;
    --space-6: 24px;
    --space-8: 32px;
    --space-10: 40px;
    --space-12: 48px;
    --space-16: 64px;

    /* ─── Border Radius ─── */
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-lg: 8px;

    /* ─── Transitions ─── */
    --transition-fast: 100ms ease;
    --transition-base: 150ms ease;
    --transition-slow: 300ms ease;
    --ease-default: cubic-bezier(0.4, 0, 0.2, 1);
    --ease-in: cubic-bezier(0.4, 0, 1, 1);
    --ease-out: cubic-bezier(0, 0, 0.2, 1);

    /* ─── Shadows (minimal Linear style) ─── */
    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 8px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 8px 16px rgba(0, 0, 0, 0.08);

    /* ─── Opacity States ─── */
    --opacity-hover: 0.85;
    --opacity-active: 0.7;
    --opacity-disabled: 0.4;
  }

  .dark {
    /* ─── Dark Mode — Backgrounds (Linear #08090a style) ─── */
    --bg-primary: #08090a;
    --bg-secondary: #0f1011;
    --bg-tertiary: #191a1b;

    /* ─── Dark Mode — Text ─── */
    --text-primary: #f7f8f8;
    --text-secondary: #d0d6e0;
    --text-tertiary: #8a8f98;

    /* ─── Dark Mode — Accents (gold preserved) ─── */
    --accent-primary: #f3d34d;
    --accent-hover: #ffe066;
    --accent-muted: #3d3820;

    /* ─── Dark Mode — Borders (Linear ultra-subtle: rgba white) ─── */
    --border-subtle: rgba(255, 255, 255, 0.06);
    --border-default: rgba(255, 255, 255, 0.1);

    /* ─── Dark Mode — States ─── */
    --success: #10b981;
    --error: #ef4444;
    --warning: #f59e0b;
    --info: #3b82f6;

    /* ─── Legacy Compat ─── */
    --background: var(--bg-primary);
    --text-color: var(--text-primary);
    --border-medium: var(--border-default);
  }

  /* ═══════════════════════════════════════════════════════════
     GLOBAL STYLES
  ═══════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    :root {
      --transition-fast: 0ms;
      --transition-base: 0ms;
      --transition-slow: 0ms;
    }
  }

  html {
    font-family: var(--font-body);
    background: var(--bg-primary);
    color: var(--text-primary);
    overflow-x: hidden;
    transition:
      background-color var(--transition-base),
      color var(--transition-base);
  }

  body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    background: var(--bg-primary);
  }

  * {
    -webkit-tap-highlight-color: transparent;
  }

  code {
    font-family: var(--font-mono);
  }

  /* ─── Interactive element base transitions ─── */
  a,
  button {
    transition:
      color var(--transition-base) var(--ease-default),
      background-color var(--transition-base) var(--ease-default),
      border-color var(--transition-base) var(--ease-default),
      opacity var(--transition-base) var(--ease-default);
  }
</style>